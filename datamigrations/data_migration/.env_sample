# AXIS source database
AXIS_DB_DRIVER=pyodbc
AXIS_DB_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=axis-host;DATABASE=AXIS;UID=axis_user;PWD=axis_password;Encrypt=yes;TrustServerCertificate=yes
AXIS_OFFICE_CODE=CFD
AXIS_EXCLUDED_STATUSES=Closed,Completed

# FOIDB target database
FOIDB_DB_DRIVER=psycopg
FOIDB_DB_CONNECTION_STRING=host=foidb-host dbname=foidb user=foidb_user password=foidb_password port=5432

# Audit metadata
DATA_MIGRATION_CREATED_BY=cfdmigration
