# Publication Service local development environment.
# Values match the docker-compose dependencies in this directory.

# Service
PORT=9085
SERVICE_NAME=publication-service
ENVIRONMENT=dev
LOG_LEVEL=INFO

# Postgres
POSTGRES_URL=postgres://foi:foi@localhost:5432/foi?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false

# Publish streams (unified — kind discriminator in payload)
REDIS_STREAM_PUBLISH_REQUESTED=publication.publish.requested
REDIS_STREAM_PUBLISH_COMPLETED=publication.publish.completed
REDIS_PUBLISH_CONSUMER_GROUP=publication-publish
REDIS_PUBLISH_CONSUMER_NAME=publish-worker-1

# Sitemap streams (unified)
REDIS_STREAM_SITEMAP_REQUESTED=publication.sitemapping.requested
REDIS_STREAM_SITEMAP_COMPLETED=publication.sitemapping.completed
REDIS_SITEMAP_CONSUMER_GROUP=publication-sitemapping
REDIS_SITEMAP_CONSUMER_NAME=sitemap-worker-1

# Unpublish streams (unified)
REDIS_STREAM_UNPUBLISH_REQUESTED=publication.unpublish.requested
REDIS_STREAM_UNPUBLISH_COMPLETED=publication.unpublish.completed
REDIS_UNPUBLISH_CONSUMER_GROUP=publication-unpublish
REDIS_UNPUBLISH_CONSUMER_NAME=unpublish-worker-1

# Event validation allowlists
SOURCE_ALLOWLIST=openinfo.enqueue.service,proactivedisclosure.enqueue.service,openinfo.workflow.service,proactivedisclosure.workflow.service
SITEMAP_SOURCE_ALLOWLIST=openinfo.workflow.service,proactivedisclosure.workflow.service
UNPUBLISH_SOURCE_ALLOWLIST=openinfo.workflow.service,proactivedisclosure.workflow.service

# Event flow tuning
CONSUMER_WORKERS=1
SCHEDULER_INTERVAL=5s
OUTBOX_INTERVAL=1s
RETRY_MAX_ATTEMPTS=5
STUCK_TIMEOUT=2m
HANDLER_TIMEOUT=30s
MAX_IN_FLIGHT_EVENTS=64
POISON_REPEAT_THRESHOLD=3
STREAM_MAXLEN=100000
STREAM_TRIM_INTERVAL=1h

# S3 / SeaweedFS
S3_ENDPOINT=http://localhost:8333
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=access_key
S3_SECRET_ACCESS_KEY=secret_key
S3_USE_PATH_STYLE=true
S3_REQUEST_TIMEOUT=30s
S3_PUBLIC_URL=http://localhost:8333

# Sitemap storage
SITEMAP_BUCKET=foi-published
SITEMAP_PREFIX=sitemap/
SITEMAP_PUBLIC_BASE_URL=http://localhost:8888/buckets/sitemap/
SITEMAP_PAGE_LIMIT=50000
